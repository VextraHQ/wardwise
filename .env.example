DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Email Delivery (optional but recommended for production)
# If not configured, admin invite/reset links can still be copied manually.
RESEND_API_KEY=""
# Primary sender used by all WardWise email (auth links, contact form, etc.).
EMAIL_FROM="WardWise <hello@wardwise.ng>"
# Destination inbox for public contact-form notifications.
CONTACT_TO_EMAIL="support@wardwise.ng"
# Optional public HTTPS origin for email images. Use this if NEXTAUTH_URL points
# at an app/admin host but email assets should load from the marketing domain.
NEXT_PUBLIC_EMAIL_ASSETS_BASE_URL="https://wardwise.ng"
# Legacy fallback — kept so existing deployments keep sending auth email until
# EMAIL_FROM is set. Prefer EMAIL_FROM for new deployments.
AUTH_FROM_EMAIL="WardWise <auth@wardwise.ng>"
# Cloudflare Turnstile
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Upstash Redis — Rate Limiting (optional: falls back gracefully if not set)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Local development skips remote rate limiting by default to avoid slow auth.
# Set to "true" only when testing rate-limit behavior locally.
ENABLE_DEV_RATE_LIMITS="false"

# PostHog Analytics (optional: only enabled after cookie consent)
NEXT_PUBLIC_POSTHOG_KEY=""
# Optional alias if you copied PostHog's docs verbatim
NEXT_PUBLIC_POSTHOG_TOKEN=""
# Use "/ingest" to route through our Next.js reverse proxy (defeats ad-blockers).
# Use "https://eu.i.posthog.com" only if you want to hit PostHog directly.
NEXT_PUBLIC_POSTHOG_HOST="/ingest"
# Set to "true" only if you want analytics during local development
NEXT_PUBLIC_ENABLE_ANALYTICS_DEV="false"
