# Database (Neon PostgreSQL)
# Pooled connection for app queries
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Direct connection for migrations
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Upstash Redis — Rate Limiting (optional: falls back gracefully if not set)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# PostHog Analytics (optional: only enabled after cookie consent)
NEXT_PUBLIC_POSTHOG_KEY=""
# Optional alias if you copied PostHog's docs verbatim
NEXT_PUBLIC_POSTHOG_TOKEN=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
# Set to "true" only if you want analytics during local development
NEXT_PUBLIC_ENABLE_ANALYTICS_DEV="false"
