generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String     @id @default(cuid())
  name        String?
  email       String     @unique
  password    String?
  role        String     @default("candidate")
  candidateId String?    @unique
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  candidate   Candidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model Candidate {
  id               String   @id @default(cuid())
  name             String
  party            String
  position         String
  isNational       Boolean  @default(false)
  stateCode        String?  // 2-letter code (e.g. "AD", "LA")
  lga              String?
  constituency     String?
  constituencyLgaIds Int[]  @default([])
  description      String?
  phone            String?
  title            String?  // Honorific: Hon., Sen., Dr., Chief, Alh.
  onboardingStatus String   @default("pending") // "pending" | "credentials_sent" | "active" | "suspended"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User?
  canvassers       Canvasser[]
  campaigns        Campaign[]
}

model Voter {
  id                 String     @id @default(cuid())
  nin                String?    @unique   // Optional — canvasser can register without NIN if person doesn't know it
  firstName          String
  middleName         String?
  lastName           String
  dateOfBirth        DateTime?  // Made optional for field registration
  yearOfBirth        Int?       // Simpler alternative to dateOfBirth for field capture
  email              String?    // Not collected in field — optional, no unique constraint
  phoneNumber        String     // Primary contact channel & secondary dedup key
  gender             String?
  occupation         String?    // Keep optional (Phase 2 field)
  religion           String?    // Keep optional (Phase 2 field)
  age                Int?       // Derived from yearOfBirth, made optional
  state              String
  lga                String
  ward               String
  pollingUnit        String
  role               String     @default("voter")
  vin                String?    // Legacy VIN field — optional
  canvasserCode      String?

  // New fields for canvasser workflow
  supportLevel       String?    // "strong" | "leaning" | "undecided"
  contactOutcome     String?    // "spoke_to" | "not_home" | "refused"
  gpsLatitude        Float?     // Silent GPS auto-capture
  gpsLongitude       Float?     // Silent GPS auto-capture
  consentGiven       Boolean    @default(false) // NDPA compliance
  notes              String?    // Canvasser notes about the voter

  registrationDate   DateTime   @default(now())
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  canvasser          Canvasser? @relation(fields: [canvasserCode], references: [code])
}

model Canvasser {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  phone        String
  candidateId  String
  ward         String?
  lga          String?
  state        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  voters       Voter[]

  @@index([candidateId])
  @@index([code])
}

// === Collect: Geo Models (database-backed) ===

model Lga {
  id          Int      @id @default(autoincrement())
  name        String
  stateCode   String   @default("AD")
  wards       Ward[]
  submissions CollectSubmission[]

  @@unique([name, stateCode])
  @@index([stateCode])
}

model Ward {
  id           Int           @id @default(autoincrement())
  name         String
  lgaId        Int
  lga          Lga           @relation(fields: [lgaId], references: [id])
  pollingUnits PollingUnit[]
  submissions  CollectSubmission[]

  @@unique([name, lgaId])
}

model PollingUnit {
  id          Int    @id @default(autoincrement())
  code        String @default("")
  name        String
  wardId      Int
  ward        Ward   @relation(fields: [wardId], references: [id])
  submissions CollectSubmission[]

  @@unique([name, wardId])
  @@index([wardId])
  @@index([code])
}

// === Collect: Campaign & Submission Models ===

model Campaign {
  id               String   @id @default(uuid())
  candidateId      String
  candidate        Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  slug             String   @unique
  candidateName    String
  candidateTitle   String?
  party            String
  constituency     String
  constituencyType String   // "federal" | "state" | "lga"
  enabledLgaIds    Int[]
  customQuestion1  String?
  customQuestion2  String?
  status           String   @default("draft")     // "draft" | "active" | "paused" | "closed"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  submissions      CollectSubmission[]
  campaignCanvassers CampaignCanvasser[]
}

model CampaignCanvasser {
  id         String   @id @default(cuid())
  campaignId String
  name       String
  phone      String
  zone       String?
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([campaignId, phone])
}

model CollectSubmission {
  id               String   @id @default(uuid())
  campaignId       String
  campaign         Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fullName         String
  phone            String
  email            String?
  sex              String
  age              Int
  occupation       String
  maritalStatus    String
  lgaId            Int?
  lga              Lga?        @relation(fields: [lgaId], references: [id])
  lgaName          String
  wardId           Int?
  ward             Ward?       @relation(fields: [wardId], references: [id])
  wardName         String
  pollingUnitId    Int?
  pollingUnit      PollingUnit? @relation(fields: [pollingUnitId], references: [id])
  pollingUnitName  String
  apcRegNumber     String?
  voterIdNumber    String?
  isVerified       Boolean  @default(false)
  role             String   // "women_leader" | "coordinator" | "youth_leader" | "member"
  customAnswer1    String?
  customAnswer2    String?
  canvasserName    String?
  canvasserPhone   String?
  isFlagged        Boolean  @default(false)
  adminNotes       String?
  createdAt        DateTime @default(now())
  auditEntries     SubmissionAuditEntry[]

  @@unique([campaignId, phone])
  @@unique([campaignId, voterIdNumber])
  @@index([campaignId])
  @@index([createdAt])
  @@index([lgaId])
  @@index([wardId])
  @@index([pollingUnitId])
}

model SubmissionAuditEntry {
  id           String   @id @default(cuid())
  submissionId String
  action       String   // "verified", "unverified", "flagged", "unflagged", "note_added", "deleted"
  userId       String
  details      String?  // JSON string with change details
  createdAt    DateTime @default(now())
  submission   CollectSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

// === Audit Log ===

model AuditLog {
  id         String   @id @default(cuid())
  action     String   // e.g. "candidate.create", "campaign.delete"
  entityType String   // "candidate", "campaign", "submission"
  entityId   String
  userId     String?  // admin who performed the action
  details    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}
