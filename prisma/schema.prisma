generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id          String     @id @default(cuid())
  name        String?
  email       String     @unique
  password    String?
  role        String     @default("candidate")
  candidateId String?    @unique
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  accounts    Account[]
  sessions    Session[]
  candidate   Candidate? @relation(fields: [candidateId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Candidate {
  id           String   @id @default(cuid())
  name         String
  party        String
  position     String
  isNational   Boolean  @default(false)
  state        String?
  lga          String?
  constituency String?
  description  String?
  supporters   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User?
  voterSelections VoterCandidateSelection[]
  canvassers   Canvasser[]
  subscriptions Subscription[]
  verificationCampaigns VerificationCampaign[]
}

model Voter {
  id                 String     @id @default(cuid())
  nin                String     @unique
  firstName          String
  middleName         String?
  lastName           String
  dateOfBirth        DateTime
  email              String     @unique
  phoneNumber        String
  gender             String?
  occupation         String?
  religion           String?
  age                Int
  state              String
  lga                String
  ward               String
  pollingUnit        String
  role               String     @default("voter")
  vin                String?    // Legacy VIN field - optional, may not be populated
  canvasserCode      String?
  surveyAnswers      Json?
  ninVerifiedAt      DateTime?  // When NIN was verified via paid verification campaign
  phoneVerifiedAt    DateTime?  // When phone was verified via SMS OTP
  ninVerificationStatus String? // "verified" | "failed" | "pending"
  phoneVerificationStatus String? // "verified" | "failed" | "pending"
  registrationDate   DateTime   @default(now())
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  lastCompletedStep  String?    // "nin" | "profile" | "location" | "candidate" | "canvasser" | "confirm"
  surveyCompleted    Boolean?   @default(false)
  candidateSelections VoterCandidateSelection[]
  canvasser          Canvasser? @relation(fields: [canvasserCode], references: [code])
}

model VoterCandidateSelection {
  id          String    @id @default(cuid())
  voterId     String
  candidateId String
  position    String
  createdAt   DateTime  @default(now())

  voter       Voter     @relation(fields: [voterId], references: [id], onDelete: Cascade)
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([voterId, position])
  @@index([voterId])
  @@index([candidateId])
  @@index([position])
}

model Canvasser {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  phone        String
  candidateId  String
  ward         String?
  lga          String?
  state        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  voters       Voter[]

  @@index([candidateId])
  @@index([code])
}

model Subscription {
  id                String   @id @default(cuid())
  candidateId       String
  tier              String   // "starter" | "standard" | "premium"
  status            String   @default("active") // "active" | "cancelled" | "expired"
  startDate         DateTime @default(now())
  endDate           DateTime?
  monthlyPrice      Int      // In kobo (₦50,000 = 5000000)
  verificationCredits Int    @default(0) // Number of NIN verifications available
  smsCredits        Int      @default(0) // Number of SMS available
  autoRenew         Boolean  @default(true)
  paymentProvider   String?  // "paystack" | "flutterwave"
  paymentReference  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  candidate         Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([status])
}

model VerificationCampaign {
  id                String   @id @default(cuid())
  candidateId       String
  name              String   // e.g., "Lagos West NIN Verification - Jan 2026"
  type              String   // "nin" | "phone" | "both"
  status            String   @default("pending") // "pending" | "running" | "completed" | "failed"
  targetCount       Int      // How many voters to verify
  completedCount    Int      @default(0)
  successCount      Int      @default(0)
  failedCount       Int      @default(0)
  costPerCheck      Int      // In kobo (₦500 = 50000)
  totalCost         Int      @default(0)
  filters           Json?    // Store ward/LGA/state filters
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  candidate         Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  verificationRecords VerificationRecord[]

  @@index([candidateId])
  @@index([status])
}

model VerificationRecord {
  id                String   @id @default(cuid())
  campaignId        String
  voterId           String
  verificationType  String   // "nin" | "phone"
  status            String   // "success" | "failed" | "pending"
  provider          String?  // "smileid" | "nimc" | "termii"
  providerResponse  Json?    // Raw API response
  errorMessage      String?
  cost              Int      // In kobo
  verifiedAt        DateTime?
  createdAt         DateTime @default(now())

  campaign          VerificationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([voterId])
  @@index([status])
}
